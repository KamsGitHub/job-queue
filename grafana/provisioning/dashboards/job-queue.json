    {
      "id": 1,
      "type": "volkovlabs-form-panel",
      "title": "Submit a Job",
      "gridPos": {
        "h": 11,
        "w": 10,
        "x": 0,
        "y": 1
      },
      "options": {
        "sync": false,
        "initial": {
          "method": "-",
          "url": "",
          "datasource": "",
          "header": [],
          "contentType": "application/json",
          "code": "",
          "highlight": false,
          "highlightColor": "red",
          "confirm": false,
          "payloadMode": "all",
          "getPayload": "return {}",
          "payload": {}
        },
        "updateEnabled": "auto",
        "update": {
          "method": "POST",
          "url": "http://localhost:3000/jobs",
          "datasource": "",
          "header": [],
          "contentType": "application/json",
          "code": "if (context.panel.response && context.panel.response.ok) {\n  context.grafana.notifySuccess(['Job submitted', 'The job was added to the queue.']);\n  context.grafana.refresh();\n} else {\n  context.grafana.notifyError(['Submission failed', 'Check the Job Type and Payload JSON and try again.']);\n}",
          "highlight": false,
          "highlightColor": "red",
          "confirm": false,
          "payloadMode": "custom",
          "getPayload": "const payload = {};\ncontext.panel.elements.forEach((element) => {\n  if (element.value === null || element.value === undefined || element.value === '') {\n    return;\n  }\n  if (element.id === 'payload') {\n    payload.payload = JSON.parse(element.value);\n  } else if (element.id === 'delaySeconds') {\n    payload.delaySeconds = Number(element.value);\n  } else {\n    payload[element.id] = element.value;\n  }\n});\nreturn payload;",
          "payload": {}
        },
        "resetAction": {
          "mode": "initial",
          "code": "",
          "datasource": "",
          "getPayload": "return {}",
          "payload": {},
          "confirm": false
        },
        "buttonGroup": {
          "orientation": "center",
          "size": "md"
        },
        "submit": {
          "variant": "primary",
          "text": "Submit Job",
          "icon": "cloud-upload",
          "foregroundColor": "",
          "backgroundColor": ""
        },
        "reset": {
          "variant": "hidden",
          "text": "Reset",
          "icon": "process",
          "foregroundColor": "",
          "backgroundColor": ""
        },
        "saveDefault": {
          "variant": "hidden",
          "text": "Save Default",
          "icon": "save"
        },
        "elements": [
          {
            "uid": "el-type",
            "id": "type",
            "title": "Job Type",
            "type": "string",
            "labelWidth": 14,
            "width": 24,
            "tooltip": "",
            "section": "",
            "unit": "",
            "value": "send-email"
          },
          {
            "uid": "el-payload",
            "id": "payload",
            "title": "Payload (JSON)",
            "type": "code",
            "labelWidth": 14,
            "width": 24,
            "tooltip": "",
            "section": "",
            "unit": "",
            "value": "{\n  \"to\": \"test@example.com\"\n}",
            "height": 140,
            "language": "json"
          },
          {
            "uid": "el-priority",
            "id": "priority",
            "title": "Priority",
            "type": "select",
            "labelWidth": 14,
            "width": 24,
            "tooltip": "",
            "section": "",
            "unit": "",
            "value": "NORMAL",
            "options": [
              {
                "value": "LOW",
                "label": "LOW"
              },
              {
                "value": "NORMAL",
                "label": "NORMAL"
              },
              {
                "value": "HIGH",
                "label": "HIGH"
              }
            ],
            "optionsSource": "Custom",
            "allowCustomValue": false
          },
          {
            "uid": "el-delay",
            "id": "delaySeconds",
            "title": "Delay (seconds, optional)",
            "type": "number",
            "labelWidth": 14,
            "width": 24,
            "tooltip": "",
            "section": "",
            "unit": "",
            "value": null,
            "min": 0
          }
        ],
        "layout": {
          "variant": "single",
          "sections": [],
          "padding": 10,
          "orientation": "vertical",
          "sectionVariant": "default"
        },
        "confirmModal": {
          "title": "Confirm",
          "body": "Please confirm",
          "columns": {
