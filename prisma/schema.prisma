// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  // Milestone 8: set once attempts reaches maxAttempts. Distinct from
  // FAILED so "will retry soon" and "permanently given up" are directly
  // queryable, instead of both being FAILED and requiring callers to know
  // to compare attempts against maxAttempts themselves.
  DEAD_LETTERED
}

// Milestone 10: three tiers, not an arbitrary int. Dispatch order is
// implemented as one dedicated Redis Stream per tier (see queue/stream.ts),
// so the tier set has to stay small and fixed — one stream per possible
// value doesn't scale to an unbounded integer priority.
enum JobPriority {
  LOW
  NORMAL
  HIGH
}

model Job {
  id      String    @id @default(uuid())
  type    String
  payload Json
  status  JobStatus @default(PENDING)
  error   String?

  // Milestone 9: optional client-supplied dedup key for POST /jobs. Unique
  // so a repeat submission with the same key can be detected via a DB
  // constraint violation (safe under concurrent requests) rather than a
  // check-then-insert race. Reserved for this since Milestone 2.
  idempotencyKey String? @unique

  // Milestone 10: which of the three per-tier Redis Streams this job was
  // dispatched onto. Stored on the row mainly for observability/queryability
  // (e.g. "how many HIGH jobs are pending") — the worker never queries
  // Postgres by priority to decide dispatch order, the stream it was
  // enqueued onto already encodes that.
  priority JobPriority @default(NORMAL)

  // Milestone 7: retry tracking. attempts increments on every failure;
  // nextRetryAt is the exponential-backoff-with-jitter deadline before
  // which processEntry() declines to re-run a failed job's handler, even
  // if the Redis-side PEL sweep reclaims its stream entry before then.
  // null once a job succeeds, or once attempts reaches maxAttempts and
  // retries permanently stop.
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  nextRetryAt DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  @@index([status])
}
