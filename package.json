{
  "name": "distributed-job-queue",
  "version": "0.1.0",
  "private": true,
  "description": "A production-grade distributed job queue built from scratch on Redis Streams and PostgreSQL.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pg": "^8.22.0",
    "pino": "^9.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.43",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.2.1",
    "prettier": "^3.3.3",
    "prisma": "^7.8.0",
    "ts-jest": "^29.2.2",
    "tsx": "^4.16.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
