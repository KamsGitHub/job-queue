NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Provisioned by docker-compose.yml
DATABASE_URL=postgresql://jobqueue:jobqueue@localhost:5432/jobqueue
REDIS_URL=redis://localhost:6379

# Milestone 6: crash recovery via the consumer group's PEL
WORKER_STALE_SWEEP_INTERVAL_MS=5000
WORKER_STALE_IDLE_MS=5000
